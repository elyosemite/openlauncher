{
  "name": "launcher",
  "version": "1.0.0",
  "description": "Cross-platform Electron command palette launcher",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"tsc -p tsconfig.main.json -w\" \"tsc -p tsconfig.renderer.json -w\" \"electron dist/main/index.js\"",
    "build": "tsc -p tsconfig.main.json && tsc -p tsconfig.renderer.json",
    "start": "electron dist/main/index.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.0.0",
    "electron": "^28.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "minisearch": "^7.2.0"
  }
}
